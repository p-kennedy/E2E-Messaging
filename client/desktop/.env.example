# Vite renderer API URL — must match where the C++ TLS server is reachable.
# Copy this file to .env and adjust for your environment.

# Local development (Python API direct, no TLS):
VITE_API_URL=http://localhost:8000

# VM / production (traffic goes through the C++ TLS server):
# VITE_API_URL=https://<VM_IP>:2213
